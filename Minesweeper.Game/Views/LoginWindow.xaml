<Window x:Class="Minesweeper.Game.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Minesweeper.Game.ViewModels"
        mc:Ignorable="d"
        Title="Minesweeper - Вход" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.DataContext>
        <local:LoginViewModel />
    </Window.DataContext>

    <Grid>
        <Border Background="White" CornerRadius="10" Padding="30" Margin="40"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#1F2937"/>

                <TextBlock Text="Потребителско име" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Парола" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="UserPasswordBox" Padding="8" FontSize="14" Margin="0,0,0,5"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" 
                           TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,5,0,15"
                           Height="40"/>

                <Button Content="{Binding SubmitButtonText}" 
                        Command="{Binding SubmitCommand}" 
                        CommandParameter="{Binding ElementName=UserPasswordBox}"
                        Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="14"
                        Padding="10" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="{Binding ToggleModeText}" 
           Foreground="#3B82F6" 
           TextDecorations="Underline" 
           HorizontalAlignment="Center" 
           Cursor="Hand" 
           Margin="0,15,0,0">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleModeCommand}"/>
                    </TextBlock.InputBindings>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>