<Window x:Class="Minesweeper.Game.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Minesweeper.Game.ViewModels"
        mc:Ignorable="d"
        Title="Minesweeper - Игра" Height="750" Width="680"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0,-38,0,0">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="#F9FAFB"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                        <Setter Property="Background" Value="#111827"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                        <Setter Property="Background" Value="#008080"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Border Margin="20" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.1" Color="Black" />
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="CornerRadius" Value="16"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                            <Setter Property="Background" Value="#1F2937"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                            <Setter Property="Background" Value="#C0C0C0"/>
                            <Setter Property="CornerRadius" Value="0"/>
                            <Setter Property="BorderThickness" Value="3,3,0,0"/>
                            <Setter Property="BorderBrush" Value="White"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EFF6FF"/>
                                <Setter Property="CornerRadius" Value="8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                        <Setter Property="Background" Value="#374151"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                        <Setter Property="Background" Value="Black"/>
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⏱️" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding TimeElapsed}" FontSize="20" FontWeight="ExtraBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#1E3A8A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                                <Setter Property="Foreground" Value="#60A5FA"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="🔄 Нова Игра" Command="{Binding RestartCommand}" 
                                Padding="15,8" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,20,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Slider x:Name="ZoomSlider" Minimum="0.3" Maximum="3.0" Value="1.0" Width="100" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="2" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FEF2F2"/>
                                <Setter Property="CornerRadius" Value="8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                        <Setter Property="Background" Value="#374151"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                        <Setter Property="Background" Value="Black"/>
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="💣" FontSize="18" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding MineCount, UpdateSourceTrigger=PropertyChanged}" Width="40" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="20" FontWeight="ExtraBold">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Foreground" Value="#991B1B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                                <Setter Property="Foreground" Value="#F87171"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Board}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="15" Columns="15"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="32" Height="32" Margin="1.5" Command="{Binding DataContext.RevealCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                    <Button.InputBindings>
                                        <MouseBinding MouseAction="RightClick" Command="{Binding DataContext.FlagCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                    </Button.InputBindings>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CellBorder" Background="{Binding Background}" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
                                                <TextBlock x:Name="CellText" Text="{Binding Content}" Foreground="{Binding Foreground}" FontSize="18" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True"/>
                                                        <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="CellBorder" Property="Background" Value="#111827"/>
                                                    <Setter TargetName="CellText" Property="Foreground" Value="#F9FAFB"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True"/>
                                                        <Condition Binding="{Binding IsRevealed}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="CellBorder" Property="Background" Value="#C0C0C0"/>
                                                    <Setter TargetName="CellBorder" Property="BorderThickness" Value="3,3,0,0"/>
                                                    <Setter TargetName="CellBorder" Property="CornerRadius" Value="0"/>
                                                </MultiDataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ElementName=ZoomSlider, Path=Value}" ScaleY="{Binding ElementName=ZoomSlider, Path=Value}"/>
                        </ItemsControl.LayoutTransform>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Foreground" Value="#4B5563"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                        <Setter Property="Foreground" Value="#D1D5DB"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Resources>
                        <RadioButton x:Name="ThemeModern" Content="Светла" IsChecked="True" Margin="0,0,10,0"/>
                        <RadioButton x:Name="ThemeDark" Content="Тъмна" Margin="0,0,10,0"/>
                        <RadioButton x:Name="ThemeRetro" Content="Ретро"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding GameStatus}" FontSize="18" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#4B5563"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                        <Setter Property="Foreground" Value="#D1D5DB"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsGameOver}" Value="True">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👤 " FontSize="16" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="{Binding PlayerName}" FontSize="16" FontWeight="ExtraBold" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ThemeDark, Path=IsChecked}" Value="True">
                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ElementName=ThemeRetro, Path=IsChecked}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="🏆 Класации" Click="OpenLeaderboard_Click" Padding="15,10" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>