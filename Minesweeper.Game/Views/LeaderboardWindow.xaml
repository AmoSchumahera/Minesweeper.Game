<Window x:Class="Minesweeper.Game.Views.LeaderboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Minesweeper.Game.ViewModels"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        Title="Зала на славата" Height="550" Width="604"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.DataContext>
        <local:LeaderboardViewModel />
    </Window.DataContext>

    <Window.Resources>
        <CollectionViewSource x:Key="SortedWeekly" Source="{Binding WeeklyScores}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="MinesCount" Direction="Descending"/>
                <scm:SortDescription PropertyName="TimeInSeconds" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <CollectionViewSource x:Key="SortedMonthly" Source="{Binding MonthlyScores}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="MinesCount" Direction="Descending"/>
                <scm:SortDescription PropertyName="TimeInSeconds" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <CollectionViewSource x:Key="SortedAllTime" Source="{Binding AllTimeScores}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="MinesCount" Direction="Descending"/>
                <scm:SortDescription PropertyName="TimeInSeconds" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <DataTemplate x:Key="RankTemplate">
            <TextBlock x:Name="RankText" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="0">
                    <Setter TargetName="RankText" Property="Text" Value="🥇"/>
                    <Setter TargetName="RankText" Property="FontSize" Value="24"/>
                    <Setter TargetName="RankText" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.9" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>

                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                    <Setter TargetName="RankText" Property="Text" Value="🥈"/>
                    <Setter TargetName="RankText" Property="FontSize" Value="24"/>
                    <Setter TargetName="RankText" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#A3A3A3" BlurRadius="15" ShadowDepth="0" Opacity="0.9" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>

                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="2">
                    <Setter TargetName="RankText" Property="Text" Value="🥉"/>
                    <Setter TargetName="RankText" Property="FontSize" Value="24"/>
                    <Setter TargetName="RankText" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#CD7F32" BlurRadius="15" ShadowDepth="0" Opacity="0.9" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>

                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="3">
                    <Setter TargetName="RankText" Property="Text" Value="4"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="4">
                    <Setter TargetName="RankText" Property="Text" Value="5"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="5">
                    <Setter TargetName="RankText" Property="Text" Value="6"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="6">
                    <Setter TargetName="RankText" Property="Text" Value="7"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="7">
                    <Setter TargetName="RankText" Property="Text" Value="8"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="8">
                    <Setter TargetName="RankText" Property="Text" Value="9"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=(ItemsControl.AlternationIndex)}" Value="9">
                    <Setter TargetName="RankText" Property="Text" Value="10"/>
                    <Setter TargetName="RankText" Property="Foreground" Value="#9CA3AF"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="Black" />
        </Border.Effect>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                <TextBlock Text="🏆" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Зала на славата" FontSize="26" FontWeight="ExtraBold" Foreground="#1F2937" VerticalAlignment="Center"/>
            </StackPanel>

            <Separator Grid.Row="1" Margin="0,0,0,10" Background="#E5E7EB"/>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">

                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>

                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#6B7280"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,3"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#3B82F6"/>
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style TargetType="ListView">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,10,0,0"/>
                    </Style>

                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="Background" Value="#F9FAFB"/>
                        <Setter Property="Foreground" Value="#4B5563"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    </Style>

                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="5,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F3F4F6"/>
                        <Setter Property="Foreground" Value="#1F2937"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="3">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="5">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="7">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="9">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Седмична">
                    <ListView ItemsSource="{Binding Source={StaticResource SortedWeekly}}" AlternationCount="10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn CellTemplate="{StaticResource RankTemplate}" Width="55"/>
                                <GridViewColumn Header="ИГРАЧ" DisplayMemberBinding="{Binding User.Username}" Width="125"/>
                                <GridViewColumn Header="МИНИ" DisplayMemberBinding="{Binding MinesCount}" Width="80"/>
                                <GridViewColumn Header="ВРЕМЕ" DisplayMemberBinding="{Binding TimeInSeconds, StringFormat={}{0} сек.}" Width="100"/>
                                <GridViewColumn Header="ДАТА" DisplayMemberBinding="{Binding DatePlayed, StringFormat=dd.MM.yyyy}" Width="100"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="Месечна">
                    <ListView ItemsSource="{Binding Source={StaticResource SortedMonthly}}" AlternationCount="10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn CellTemplate="{StaticResource RankTemplate}" Width="55"/>
                                <GridViewColumn Header="ИГРАЧ" DisplayMemberBinding="{Binding User.Username}" Width="125"/>
                                <GridViewColumn Header="МИНИ" DisplayMemberBinding="{Binding MinesCount}" Width="80"/>
                                <GridViewColumn Header="ВРЕМЕ" DisplayMemberBinding="{Binding TimeInSeconds, StringFormat={}{0} сек.}" Width="100"/>
                                <GridViewColumn Header="ДАТА" DisplayMemberBinding="{Binding DatePlayed, StringFormat=dd.MM.yyyy}" Width="100"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

                <TabItem Header="All-Time">
                    <ListView ItemsSource="{Binding Source={StaticResource SortedAllTime}}" AlternationCount="10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn CellTemplate="{StaticResource RankTemplate}" Width="55"/>
                                <GridViewColumn Header="ИГРАЧ" DisplayMemberBinding="{Binding User.Username}" Width="125"/>
                                <GridViewColumn Header="МИНИ" DisplayMemberBinding="{Binding MinesCount}" Width="80"/>
                                <GridViewColumn Header="ВРЕМЕ" DisplayMemberBinding="{Binding TimeInSeconds, StringFormat={}{0} сек.}" Width="100"/>
                                <GridViewColumn Header="ДАТА" DisplayMemberBinding="{Binding DatePlayed, StringFormat=dd.MM.yyyy}" Width="100"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</Window>